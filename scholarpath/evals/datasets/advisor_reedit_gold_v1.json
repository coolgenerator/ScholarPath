{
  "dataset_id": "advisor_reedit_gold_v1",
  "version": "1.0.0",
  "strict_thresholds": {
    "reedit_overwrite_success_rate": 0.95,
    "reedit_truncation_correct_rate": 0.95,
    "reedit_history_consistency_rate": 0.95
  },
  "cases": [
    {
      "case_id": "ar-001",
      "request": {
        "message": "把第二轮我的定位改成计算机科学+数学双专业。",
        "edit": {
          "target_turn_id": "turn-2",
          "mode": "overwrite"
        }
      },
      "seed": {
        "timeline": [
          {"turn_id": "turn-1", "role": "user", "content": "我想做本科择校"},
          {"turn_id": "turn-1", "role": "assistant", "content": "先说下你的专业方向"},
          {"turn_id": "turn-2", "role": "user", "content": "我只想学经济学"},
          {"turn_id": "turn-2", "role": "assistant", "content": "好的，按经济学准备"},
          {"turn_id": "turn-3", "role": "user", "content": "预算是5万"}
        ]
      },
      "expect": {
        "overwrite_success": true,
        "truncation_correct": true,
        "history_consistent": true,
        "contract_ok": true,
        "capability_any": ["undergrad.school.recommend", "undergrad.school.query", "undergrad.strategy.plan"]
      },
      "tags": ["cat_reedit_middle", "lang_zh"]
    },
    {
